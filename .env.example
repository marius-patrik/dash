# =============================================
# Server Environment Variables
# =============================================

# Claude Auth (pick one)
# Option 1: Max subscription OAuth token (run `claude setup-token` first)
CLAUDE_CODE_OAUTH_TOKEN=

# Option 2: Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=

# Supabase (get from: https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Server
PORT=3001
HOST=0.0.0.0

# =============================================
# Client Environment Variables (Vercel)
# Set these in Vercel Dashboard > Project > Settings > Environment Variables
# =============================================

# Supabase (same project URL + anon key as above)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API URL — points to wherever the server is deployed
# For local dev:
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# For production (replace with your server URL):
# NEXT_PUBLIC_API_URL=https://your-server.fly.dev
# NEXT_PUBLIC_WS_URL=wss://your-server.fly.dev
