# Claude Auth (pick one)
# Option 1: Max subscription OAuth token (run `claude setup-token` first)
CLAUDE_CODE_OAUTH_TOKEN=

# Option 2: Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Server
PORT=3001
HOST=0.0.0.0
