# =============================================
# Convex + Clerk Environment Variables
# =============================================

# Convex (get from: https://dashboard.convex.dev)
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Clerk (get from: https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Set these as Convex environment variables (npx convex env set KEY VALUE):
# CLERK_SECRET_KEY=sk_test_...
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token
# ANTHROPIC_API_KEY=your-api-key (alternative to OAuth token)
