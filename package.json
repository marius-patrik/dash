{
  "name": "dash",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:server": "bun run --filter @dash/server dev",
    "dev:client": "bun run --filter @dash/client dev",
    "build": "bun run --filter @dash/shared build && bun run --filter @dash/client build && bun run --filter @dash/server build",
    "start": "bun run --filter @dash/server start",
    "check": "biome check --write .",
    "lint": "biome lint ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  }
}
