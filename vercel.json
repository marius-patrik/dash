{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd packages/client && bun run build",
  "outputDirectory": "packages/client/dist",
  "installCommand": "bun install",
  "framework": null,
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
